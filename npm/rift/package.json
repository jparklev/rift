{
  "name": "@jparklev/rift",
  "version": "0.0.11",
  "description": "Fast copy-on-write development workspaces",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jparklev/rift.git"
  },
  "type": "module",
  "bin": {
    "rift": "bin/rift.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "bun": "./bun/index.js",
      "node": "./node/index.js",
      "default": "./node/index.js"
    }
  },
  "files": [
    "bin",
    "bun",
    "node",
    "index.d.ts",
    "native.js"
  ],
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "arm64",
    "x64"
  ],
  "optionalDependencies": {
    "@jparklev/rift-darwin-arm64": "0.0.11",
    "@jparklev/rift-darwin-x64": "0.0.11",
    "@jparklev/rift-linux-arm64": "0.0.11",
    "@jparklev/rift-linux-x64": "0.0.11",
    "@jparklev/rift-windows-arm64": "0.0.11",
    "@jparklev/rift-windows-x64": "0.0.11"
  },
  "engines": {
    "node": ">=26.1.0",
    "bun": ">=1.3.14"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
