{
  "name": "rift-snapshot",
  "version": "0.0.3",
  "description": "Fast copy-on-write development workspaces",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/rift.git"
  },
  "bin": {
