    "x64"
  ],
  "optionalDependencies": {
    "rift-snapshot-darwin-arm64": "0.0.3",
    "rift-snapshot-darwin-x64": "0.0.3",
    "rift-snapshot-linux-x64": "0.0.3",
    "rift-snapshot-windows-x64": "0.0.3"
  },
  "publishConfig": {
    "provenance": true
  }
}
