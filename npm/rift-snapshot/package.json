{
  "name": "rift-snapshot",
  "version": "0.0.5",
  "description": "Fast copy-on-write development workspaces",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/rift.git"
  },
  "type": "module",
  "bin": {
    "rift": "bin/rift.js"
  },
  "exports": {
    "./bun": {
      "types": "./bun/index.d.ts",
      "default": "./bun/index.js"
    }
  },
  "files": [
    "bin",
    "bun",
    "prebuilds"
  ],
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "arm64",
    "x64"
  ],
  "publishConfig": {
    "provenance": true
  }
}
